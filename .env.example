# Database
# Local dev:   DATABASE_URL="file:./dev.db"
# Turso (prod): DATABASE_URL="libsql://your-db-name-your-org.turso.io"
DATABASE_URL="file:./dev.db"
DATABASE_AUTH_TOKEN=""  # Turso auth token (not needed for local dev)

# Auth.js
AUTH_SECRET=""       # Generate with: npx auth secret
AUTH_URL=""          # e.g. http://localhost:3000 (dev) or https://your-domain.com (prod)

# Optional: Set to "production" or "development"
NODE_ENV="development"
